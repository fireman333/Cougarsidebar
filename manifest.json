{
  "manifest_version": 3,
  "name": "解題心流",
  "version": "1.0.0",
  "description": "選取題目送給 AI 解答，自動記錄並匯出 Markdown 筆記",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "downloads",
    "clipboardWrite",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script-main.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://www.google.com/*"
      ],
      "js": ["content-script-ai.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "commands": {
    "send-to-ai": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "MacCtrl+Shift+Q"
      },
      "description": "將選取文字送給 AI 解題"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "modify_headers",
        "enabled": true,
        "path": "rules/modify-headers.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar/sidebar.html",
        "selectors/gemini.json",
        "selectors/chatgpt.json",
        "selectors/claude.json",
        "selectors/google-ai.json"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
